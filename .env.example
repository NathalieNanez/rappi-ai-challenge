# Anthropic API Key for Claude 3.5 Sonnet
# Reemplaza 'tu_api_key_aqui' con tu token real de Anthropic.
ANTHROPIC_API_KEY=

# Ruta relativa o absoluta al archivo de datos de Excel
DATA_PATH=data/raw/rappi_data.xlsx

# Parámetros opcionales del agente
MAX_CONVERSATION_TURNS=20


# Variable de entorno BREVO_API_KEY y SENDER
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# Correo registrado en Brevo
BREVO_SENDER_EMAIL=tucorreo@gmail.com